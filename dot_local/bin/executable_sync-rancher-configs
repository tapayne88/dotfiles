#!/bin/bash

set -euo pipefail

# Example configuration file format:
# ~/.config/rancher-clusters.yaml
#
# rancher_instances:
#   - name: "prod-rancher"
#     url: "https://rancher.example.com"
#     token: "token-abc123..."
#   - name: "dev-rancher"
#     url: "https://dev-rancher.example.com"
#     token: "token-def456..."
#
# File should have 0600 permissions for security:
# chmod 600 ~/.config/rancher-clusters.yaml

# Configuration
CONFIG_FILE="$HOME/.config/rancher-clusters.yaml"
KUBIE_CONFIGS_DIR="$HOME/.kube/configs"
TEMP_DIR=$(mktemp -d)

# Colors (disabled automatically when stdout is not a terminal, e.g. piped to a file)
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
    BLUE=$'\033[0;34m'; DIM=$'\033[2m'; BOLD=$'\033[1m'; NC=$'\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; DIM=''; BOLD=''; NC=''
fi

# Top-level line (no indent)
info() { printf '%s\n' "$*"; }
# Instance section header
section() { printf '\n%s==> %s%s\n' "$BOLD$BLUE" "$*" "$NC"; }
# Indented detail under a section
step() { printf '    %s\n' "$*"; }
# Indented outcomes under a section
ok()   { printf '    %s✓%s %s\n' "$GREEN" "$NC" "$*"; }
fail() { printf '    %s✗%s %s\n' "$RED" "$NC" "$*" >&2; }
# Top-level warning / fatal error
warn()  { printf '%s! %s%s\n' "$YELLOW" "$*" "$NC" >&2; }
error() { printf '%sError:%s %s\n' "$RED" "$NC" "$*" >&2; }

cleanup() {
    rm -rf "$TEMP_DIR"
    # Logout from rancher if logged in
    rancher logout >/dev/null 2>&1 || true
}

trap cleanup EXIT

check_dependencies() {
    local missing=()

    if ! command -v rancher >/dev/null 2>&1; then
        missing+=("rancher")
    fi

    if ! command -v yq >/dev/null 2>&1; then
        missing+=("yq")
    fi

    if ! command -v jq >/dev/null 2>&1; then
        missing+=("jq")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing required dependencies: ${missing[*]}"
        error "Please install the missing tools and try again."
        exit 1
    fi
}

check_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        error "Configuration file not found: $CONFIG_FILE"
        error "Please create the config file with your rancher instances."
        exit 1
    fi

    # Check file permissions (cross-platform: BSD/macOS vs GNU/Linux stat)
    local perms
    perms=$(stat -c '%a' "$CONFIG_FILE" 2>/dev/null || stat -f '%Lp' "$CONFIG_FILE" 2>/dev/null)

    if [[ "$perms" != "600" ]]; then
        warn "Config file permissions should be 600 (owner read/write only)"
        warn "Run: chmod 600 $CONFIG_FILE"
    fi
}

get_available_clusters() {
    local url="$1"
    local token="$2"

    # Run login + cluster discovery under a single 10s timeout so a hung or
    # unreachable instance is abandoned rather than blocking the whole sync.
    # Exit codes: 124 = timed out, 1 = login failed, 0 = success.
    timeout 10 bash -c '
        set -o pipefail
        echo "1" | rancher login "$1" --token "$2" --skip-verify >/dev/null 2>&1 || exit 1
        rancher cluster ls --format json 2>/dev/null | jq -r ".Cluster.name"
    ' _ "$url" "$token"
}

sync_rancher_instance() {
    local name="$1"
    local url="$2"
    local token="$3"
    local instance_num="$4"
    local instance_total="$5"

    section "$name (instance $instance_num/$instance_total)"
    step "${DIM}$url${NC}"

    # Discover clusters (login + list) under the timeout in get_available_clusters
    local clusters rc
    clusters=$(get_available_clusters "$url" "$token") && rc=0 || rc=$?

    if [[ "$rc" -eq 124 ]]; then
        fail "timed out after 10s discovering clusters — skipping"
        return 1
    fi

    if [[ -z "$clusters" ]]; then
        fail "could not connect or no clusters found — skipping"
        return 1
    fi

    local cluster_count
    cluster_count=$(echo "$clusters" | wc -l | tr -d ' ')
    step "$cluster_count cluster(s) found"

    local processed_count=0
    local cluster_index=1
    local idx_width=${#cluster_count}   # pad the index so 9→10 doesn't shift the column

    while IFS= read -r cluster; do
        [[ -z "$cluster" ]] && continue

        # Start the cluster's line; the outcome is appended once work completes
        printf '    %s[%*d/%d]%s %-28s ' "$DIM" "$idx_width" "$cluster_index" "$cluster_count" "$NC" "$cluster"

        if echo "$cluster_index" | rancher login "$url" --token "$token" --skip-verify >/dev/null 2>&1; then
            local temp_config="$TEMP_DIR/${cluster}.yaml"
            if rancher kubectl config view --raw=true > "$temp_config" 2>/dev/null && [[ -s "$temp_config" ]]; then
                mv "$temp_config" "$KUBIE_CONFIGS_DIR/${cluster}.yaml"
                printf '%s✓%s synced\n' "$GREEN" "$NC"
                processed_count=$((processed_count + 1))
            else
                printf '%s✗%s config export failed\n' "$RED" "$NC"
            fi
            rancher logout >/dev/null 2>&1 || true
        else
            printf '%s✗%s login failed\n' "$RED" "$NC"
        fi

        cluster_index=$((cluster_index + 1))
    done <<< "$clusters"

    if [[ "$processed_count" -eq "$cluster_count" ]]; then
        ok "$processed_count/$cluster_count clusters synced"
    else
        step "${YELLOW}! $processed_count/$cluster_count clusters synced${NC}"
    fi
}

main() {
    info "${BOLD}rancher → kubie config sync${NC}"

    check_dependencies
    check_config

    # Ensure kubie configs directory exists
    mkdir -p "$KUBIE_CONFIGS_DIR"

    # Read and process each rancher instance
    local instance_count
    instance_count=$(yq '.rancher_instances | length' "$CONFIG_FILE")

    if [[ "$instance_count" -eq 0 ]] || [[ "$instance_count" == "null" ]]; then
        error "no rancher instances found in $CONFIG_FILE"
        exit 1
    fi

    info "${DIM}$instance_count instance(s) → $KUBIE_CONFIGS_DIR${NC}"

    local i name url token
    for ((i=0; i<instance_count; i++)); do
        name=$(yq -r ".rancher_instances[$i].name" "$CONFIG_FILE")
        url=$(yq -r ".rancher_instances[$i].url" "$CONFIG_FILE")
        token=$(yq -r ".rancher_instances[$i].token" "$CONFIG_FILE")

        if [[ -z "$name" ]] || [[ -z "$url" ]] || [[ -z "$token" ]]; then
            section "instance $((i+1))/$instance_count"
            fail "invalid config (missing name, url, or token) — skipping"
            continue
        fi

        # sync_rancher_instance already reports its own skip reason on failure
        sync_rancher_instance "$name" "$url" "$token" "$((i+1))" "$instance_count" || continue
    done

    printf '\n%s✓ done%s — configs in %s\n' "$GREEN$BOLD" "$NC" "$KUBIE_CONFIGS_DIR"
    info "${DIM}run 'kubie ctx' to switch between clusters${NC}"
}

# Show help if requested
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    echo "Usage: $(basename "$0")"
    echo ""
    echo "Syncs kubectl configs from multiple rancher instances to kubie."
    echo "Configuration file: $CONFIG_FILE"
    echo "Output directory: $KUBIE_CONFIGS_DIR"
    echo ""
    echo "The script will:"
    echo "1. Read rancher instances from the config file"
    echo "2. Login to each rancher instance"
    echo "3. Discover available clusters"
    echo "4. Export kubectl configs for each cluster"
    echo "5. Place configs in the kubie configs directory"
    exit 0
fi

main "$@"
