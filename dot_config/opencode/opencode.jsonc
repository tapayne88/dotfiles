{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "share": "disabled",
  "disabled_providers": ["opencode"],
  "model": "github-copilot/claude-sonnet-4",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true,
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true,
    },
    "tilt-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@0xbigboss/tilt-mcp"],
      "environment": {
        "TILT_PORT": "10350",
      },
      "enabled": true,
    },
  },
}
